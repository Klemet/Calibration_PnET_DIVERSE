{"version":3,"kind":"Notebook","sha256":"d34173bfb070e0eb3585f40098bcfb28f3ceb4dadb1fa3f1a79a281b131776c2","slug":"startingcalibrationtest.goals-and-assumptions","location":"/StartingCalibrationTest/0.2.Goals_and_assumptions.ipynb","dependencies":[],"frontmatter":{"title":"Notebook 0.2 - Goals and assumptions of this calibration","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"Clément Hardy, PhD.","given":"PhD.","family":"Clément Hardy"},"name":"Clément Hardy, PhD.","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/Klemet/PnET-Succession_Calibration_Tool","numbering":{"title":{"offset":1}},"source_url":"https://github.com/Klemet/PnET-Succession_Calibration_Tool/blob/main/calibrationJupyterBook/StartingCalibrationTest/0.2.Goals_and_assumptions.ipynb","edit_url":"https://github.com/Klemet/PnET-Succession_Calibration_Tool/edit/main/calibrationJupyterBook/StartingCalibrationTest/0.2.Goals_and_assumptions.ipynb","exports":[{"format":"ipynb","filename":"0.2.Goals_and_assumptions.ipynb","url":"https://klemet.github.io/PnET-Succession_Calibration_Tool/build/0.2.Goals_and_assump-a7e8d64f7bef8bf669cf654855ed9268.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Goals of these notebooks","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ozYyfcTGpB"}],"identifier":"goals-of-these-notebooks","label":"Goals of these notebooks","html_id":"goals-of-these-notebooks","implicit":true,"key":"YLmLz9qDRt"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The goal of these notebooks is to calibrate 3 tree species for a study landscape in Quebec, Canada.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"mXXwIRKOeZ"}],"key":"d4lQjQircJ"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"I limit things to 6 tree species as these notebooks are a proof of concept that will be used, if successful, for further calibration of more species in different Canadian landscapes.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"zOf4sut2ok"}],"key":"CLKgL0a55F"},{"type":"paragraph","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"The study landscape used here in Quebec, Canada, corresponds to a part of the territory of the Atikamekw first nation community of Manawan. This territory has been used before for previous LANDIS-II simulation, which will make comparisons to previous parameterization with Biomass Succession easier.","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"Iq65unJ3QJ"}],"key":"deiC4y19Ep"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Here is a map showing the extent of the study landscape in space :","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"j7PqnykjWd"}],"key":"MfekachA14"}],"key":"SfTZ16hdjg"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Displays a map where the shapefile that defines the boundaries of the climate data we wanna use is\nimport geopandas as gpd\nimport folium\nfrom folium.features import GeoJsonPopup, GeoJsonTooltip\n\n# Load the shapefile\n# Replace 'path_to_shapefile.shp' with your actual shapefile path\ngdf = gpd.read_file(\"./ReferencesAndData/SpatialBoundaries/ManawanTerritoryExtent.shp\")\n\n# Check the CRS (Coordinate Reference System) of the shapefile\n# If not in WGS84 (EPSG:4326), reproject it\nif gdf.crs != 'EPSG:4326':\n    gdf = gdf.to_crs('EPSG:4326')\n\n# Create a map centered on the mean of the shapefile bounds\ncenter_lat = gdf.unary_union.centroid.y\ncenter_lon = gdf.unary_union.centroid.x\nm = folium.Map(location=[center_lat, center_lon], zoom_start=6)\n\n# Add the GeoJSON data to the map with some styling\nfolium.GeoJson(\n    gdf,\n    name='Polygons',\n    style_function=lambda x: {\n        'fillColor': '#ebcb8b',\n        'color': '#2e3440',\n        'weight': 1,\n        'fillOpacity': 0.4\n    }\n).add_to(m)\n\n# Add layer control\nfolium.LayerControl().add_to(m)\n\n# Alternatively, you can use this simpler approach which works in newer versions of JupyterLab\ndisplay(m)","key":"V5fzNTpftn"},{"type":"outputs","id":"sLl0VYatBzMUMqD6cwSnn","children":[{"type":"output","jupyter_data":{"name":"stderr","output_type":"stream","text":"/tmp/ipykernel_169/1915607144.py:16: DeprecationWarning: The 'unary_union' attribute is deprecated, use the 'union_all()' method instead.\n  center_lat = gdf.unary_union.centroid.y\n/tmp/ipykernel_169/1915607144.py:17: DeprecationWarning: The 'unary_union' attribute is deprecated, use the 'union_all()' method instead.\n  center_lon = gdf.unary_union.centroid.x\n"},"children":[],"key":"mYoh3DedQA"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/html":{"content":"<div style=\"width:100%;\"><div style=\"position:relative;width:100%;height:0;padding-bottom:60%;\"><span style=\"color:#565656\">Make this Notebook Trusted to load map: File -> Trust Notebook</span><iframe srcdoc=\"&lt;!DOCTYPE html&gt;\n&lt;html&gt;\n&lt;head&gt;\n    \n    &lt;meta http-equiv=&quot;content-type&quot; content=&quot;text/html; charset=UTF-8&quot; /&gt;\n    &lt;script src=&quot;https://cdn.jsdelivr.net/npm/leaflet@1.9.3/dist/leaflet.js&quot;&gt;&lt;/script&gt;\n    &lt;script src=&quot;https://code.jquery.com/jquery-3.7.1.min.js&quot;&gt;&lt;/script&gt;\n    &lt;script src=&quot;https://cdn.jsdelivr.ne