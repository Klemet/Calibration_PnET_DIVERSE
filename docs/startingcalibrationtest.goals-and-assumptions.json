n                overlays :  {\n                    &quot;Polygons&quot; : geo_json_1fc09ce7f8f37de4b61be106f034c96f,\n                },\n            };\n            let layer_control_890a773185e00de1d26890dba6c97ec1 = L.control.layers(\n                layer_control_890a773185e00de1d26890dba6c97ec1_layers.base_layers,\n                layer_control_890a773185e00de1d26890dba6c97ec1_layers.overlays,\n                {\n  &quot;position&quot;: &quot;topright&quot;,\n  &quot;collapsed&quot;: true,\n  &quot;autoZIndex&quot;: true,\n}\n            ).addTo(map_a5ebce65473903de4421bfb903ce38ed);\n\n        \n&lt;/script&gt;\n&lt;/html&gt;\" style=\"position:absolute;width:100%;height:100%;left:0;top:0;border:none !important;\" allowfullscreen webkitallowfullscreen mozallowfullscreen></iframe></div></div>","content_type":"text/html"},"text/plain":{"content":"<folium.folium.Map at 0x7aa53c0ab460>","content_type":"text/plain"}}},"children":[],"key":"Gtpj4APKtI"}],"key":"dtTdhqGV4v"}],"key":"t9jYfvmmhf"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Assumptions","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"rfJwAYYmUi"}],"identifier":"assumptions","label":"Assumptions","html_id":"assumptions","implicit":true,"key":"sKjO85Ywy3"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"As per ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JKBlhDZHnl"},{"type":"cite","url":"https://doi.org/10.1139/cjfr-2024-0085","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Reese et al., 2024","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"vSLIX1RvV4"}],"kind":"narrative","label":"Reese_2025","identifier":"https://doi.org/10.1139/cjfr-2024-0085","enumerator":"1","key":"XRhM0RcwzA"},{"type":"text","value":" and other works, it is very important to document the assumptions (untested hypothesis) behind the choices done during the calibration.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"BjGb6NCG6R"}],"key":"GbX4ES3oSZ"},{"type":"paragraph","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"children":[{"type":"text","value":"Here, I catalog the different assumptions done throughout the calibration process. There is no need for you to learn or understand them all for now, as they will make sense while reading the rest of the notebooks.","position":{"start":{"line":5,"column":1},"end":{"line":5,"column":1}},"key":"LvQEvZiEBR"}],"key":"jk81IgBR3C"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":7,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Species parameters of different geographic source (e.g. derived from measurements made from trees outside of the study landscape in Quebec, or from trees of different geographic origin) can be used and are used in this calibration. We assume that despite the different geographic origin of these parameters, which might represent the behavior/biology of different variants or phenotypes, the calibration process will still allow us to tweak the values of the most important parameters influencing the growth of the tree species in the study landscape so as to properly replicate the behavior/physiology of the tree variants/phenotypes inside the study landscape. See ","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"bRIO6pBUDy"},{"type":"link","url":"/startingcalibrationtest/initial-species-parameters","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"children":[{"type":"text","value":"3​.Initial​_Species​_Parameters​.ipynb","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"yjmQ9lnGJ9"}],"urlSource":"./3.Initial_Species_Parameters.ipynb","dataUrl":"/startingcalibrationtest.initial-species-parameters.json","internal":true,"protocol":"file","key":"t2L87avaFA"},{"type":"text","value":".","position":{"start":{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"AA52Xdqj82"}],"key":"oT8WY6Gdbl"}],"key":"zIhlkUEL12"},{"type":"listItem","spread":true,"position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The raster data from the National Forest Inventory, which represents the biomass of a given tree species inside pixels of a certain forest age, can be used through a space-for-time approach as way to estimate the growth curves for this tree species. In particular, we assume that the maximum biomass reached for a certain species at a certain age, visible through the combination of the many data points that each pixel represent, is a good estimate of the growth peak that can be achieved by the tree species. See ","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"O1dAWzoDQi"},{"type":"link","url":"/startingcalibrationtest/getting-the-empirical-data","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"4​.Getting​_the​_empirical​_data​.ipynb","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"lNzLr9Nwxk"}],"urlSource":"./4.Getting_the_empirical_data.ipynb","dataUrl":"/startingcalibrationtest.getting-the-empirical-data.json","internal":true,"protocol":"file","key":"Hn1U1CI7Jt"},{"type":"text","value":".","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"sNxxQPlkKi"}],"key":"za1gjUXo29"}],"key":"F3pHklrW8w"},{"type":"listItem","spread":true,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"The longevity values derived from ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"iGJOgH2L3n"},{"type":"cite","url":"https://cdnsciencepub.com/doi/10.1139/x88-032","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Loehle (1988)","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"l0Y0i2TPSz"}],"kind":"narrative","label":"Loehle_1988","identifier":"https://cdnsciencepub.com/doi/10.1139/x88-032","enumerator":"2","key":"rdCbxcpyBE"},{"type":"text","value":" are a good estimate of the longevity of the tree species in our study area, despite the fact that the longevity of trees can change depending on their place of growth. See ","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"UEWrbT6Vzz"},{"type":"link","url":"/startingcalibrationtest/getting-the-empirical-data","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"4​.Getting​_the​_empirical​_data​.ipynb","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"xgLvF98M7C"}],"urlSource":"./4.Getting_the_empirical_data.ipynb","dataUrl":"/startingcalibrationtest.getting-the-empirical-data.json","internal":true,"protocol":"file","key":"fIP4PSWQQG"},{"type":"text","value":".","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"rS9gmJCgvy"}],"key":"zSGP3Px8nW"}],"key":"f37rvHyFCC"},{"type":"listItem","spread":true,"position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"While species’ tolerance to shade, drought, watterlogging, temperature (as described in the ","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"JNJtFs9UbA"},{"type":"link","url":"https://www.try-db.org","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"TRY database","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"UF8sm8c2NK"}],"urlSource":"https://www.try-db.org","key":"i48ZOog3T8"},{"type":"text","value":") can change depending on the variant/genotype inside a species, we assume that the relative difference between species will remain the same (e.g. if tree species A has a shade tolerance of 1 in the TRY database and tree species B has a shade tolerance of 3, then tree species A will remain much more shade intolerance than B whatever the landscape considered).","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"ruBg6XWxAa"}],"key":"clVRM6KCfI"}],"key":"BQH2ByVSBW"}],"key":"tQzU5ApvrA"}],"key":"rwsECOgP5T"}],"key":"IUtxHrn7L8"},"references":{"cite":{"order":["Reese_2025","Loehle_1988"],"data":{"Reese_2025":{"label":"Reese_2025","enumerator":"1","doi":"10.1139/cjfr-2024-0085","html":"Reese, G. C., Sturtevant, B. R., Dymond, C. C., Quigley, K. M., Duveneck, M. J., Lucash, M. S., Gustafson, E. J., Scheller, R. M., Russell, M. B., & Miranda, B. R. (2025). Best practices for calibration of forest landscape models using fine-scaled reference information. <i>Canadian Journal of Forest Research</i>, <i>55</i>, 1–19. <a target=\"_blank\" rel=\"noreferrer\" href=\"https://doi.org/10.1139/cjfr-2024-0085\">10.1139/cjfr-2024-0085</a>","url":"https://doi.org/10.1139/cjfr-2024-0085"},"Loehle_1988":{"label":"Loehle_1988","enumerator":"2","doi":"10.1139/x88-032","html":"Loehle, C. (1988). Tree life history strategies: the role of defenses. <i>Canadian Journal of Forest Research</i>, <i>18</i>(2), 209–222. <a target=\"_blank\" rel=\"noreferrer\" href=\"https://doi.org/10.1139/x88-032\">10.1139/x88-032</a>","url":"https://doi.org/10.1139/x88-032"}}}},"footer":{"navigation":{"prev":{"title":"Notebook 0.1 - Some important notions before we start","url":"/startingcalibrationtest/some-important-notions","group":"PnET-Succession Calibration Tool"},"next":{"title":"Notebook 1 - Loading the functions and packages needed for the code of these notebooks","url":"/startingcalibrationtest/loading-functions","group":"PnET-Succession Calibration Tool"}}},"domain":"http://localhost:3000"}